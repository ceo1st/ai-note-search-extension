{
  "manifest_version": 3,
  "name": "AI 笔记语义搜索",
  "description": "基于本地 AI 嵌入模型的笔记语义搜索扩展，支持离线搜索和关键词降级搜索",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs"]
}
